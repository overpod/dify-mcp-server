{
  "name": "dify-mcp-server",
  "version": "0.7.0",
  "description": "MCP server for Dify Console API — programmatic agent/app creation, knowledge base management, workflow control",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dify-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "bun dist/index.js",
    "dev": "bun --watch src/index.ts",
    "check": "biome check src/",
    "fix": "biome check --write src/",
    "test": "bun vitest run",
    "test:watch": "bun vitest"
  },
  "keywords": [
    "mcp",
    "dify",
    "ai",
    "agent",
    "claude",
    "model-context-protocol",
    "knowledge-base"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/overpod/dify-mcp-server"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
